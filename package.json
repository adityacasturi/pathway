{
  "name": "pathway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": [
      "./*",
      "./*.ts",
      "./*.tsx"
    ]
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "node tests/run-unit.mjs",
    "test:unit:coverage": "node tests/run-unit.mjs --coverage",
    "test:preprod": "npm run typecheck && npm audit --audit-level=moderate && npm run test:unit && npm run build",
    "test:preprod:full": "npm run lint && npm run test:preprod && npm run test:e2e",
    "scrape": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/scrape.ts",
    "scrape:audit": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/audit-scrape-quality.ts",
    "scrape:audit-posted-dates": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/audit-posted-dates.ts",
    "scrape:audit-adapters": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/audit-adapter-patterns.ts",
    "scrape:audit-locations": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/audit-locations.ts",
    "alerts:instant": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/send-instant-alerts.ts",
    "build:gazetteer": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/build-gazetteer.ts",
    "backfill:locations": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/backfill-locations.ts",
    "discover-queue": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/discover-queue.ts",
    "discover-company": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/discover-company.ts",
    "company-logos": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/download-company-logos.ts",
    "revalidate-catalog": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-specifier-resolution=node scripts/revalidate-catalog.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "npm run lint && npm run test:preprod",
    "postinstall": "node scripts/ensure-heroui-styles.mjs"
  },
  "dependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-aria-components": "^1.17.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
